{
  "name": "dashboard",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "dashboard",
    "sourceRoot": "apps/dashboard/src",
    "targets": {
      "build": {
        "executor": "@nx/webpack:webpack",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "compiler": "babel",
          "outputPath": "apps/dashboard/dist",
          "index": "apps/dashboard/src/index.html",
          "baseHref": "/",
          "main": "apps/dashboard/src/main.ts",
          "tsConfig": "apps/dashboard/tsconfig.app.json",
          "assets": [
            "apps/dashboard/src/favicon.ico",
            "apps/dashboard/src/assets"
          ],
          "styles": [
            "apps/dashboard/src/styles.css"
          ],
          "scripts": [],
          "webpackConfig": "apps/dashboard/webpack.config.ts"
        },
        "configurations": {
          "development": {
            "extractLicenses": false,
            "optimization": false,
            "sourceMap": true,
            "vendorChunk": true
          },
          "production": {
            "fileReplacements": [
              {
                "replace": "apps/dashboard/src/environments/environment.ts",
                "with": "apps/dashboard/src/environments/environment.prod.ts"
              }
            ],
            "optimization": true,
            "outputHashing": "all",
            "sourceMap": false,
            "namedChunks": false,
            "extractLicenses": true,
            "vendorChunk": false
          }
        },
        "dependsOn": [
          "^build",
          "typecheck"
        ]
      },
      "serve": {
        "executor": "@nx/react:module-federation-dev-server",
        "defaultConfiguration": "development",
        "options": {
          "buildTarget": "dashboard:build",
          "hmr": true,
          "port": 4200,
          "devRemotes": ["event_forms"]
        },
        "configurations": {
          "development": {
            "buildTarget": "dashboard:build:development"
          },
          "production": {
            "buildTarget": "dashboard:build:production",
            "hmr": false
          }
        },
        "dependsOn": [
          "typecheck"
        ]
      },
      "serve-static": {
        "executor": "@nx/react:module-federation-static-server",
        "defaultConfiguration": "production",
        "options": {
          "serveTarget": "dashboard:serve"
        },
        "configurations": {
          "development": {
            "serveTarget": "dashboard:serve:development"
          },
          "production": {
            "serveTarget": "dashboard:serve:production"
          }
        }
      }
    }
  },
  "devDependencies": {
    "event_forms": "*"
  }
}
